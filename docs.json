{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "venus",
  "name": "Breaknine",
  "colors": {
    "primary": "#0b2b26",
    "light": "#8ebc9b",
    "dark": "#051f20"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0a0908"
    }
  },
  "font": {
    "headings": {
      "family": "Source Sans 3"
    },
    "body": {
      "family": "Source Sans 3"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Changelog",
        "pages": ["changelog"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://app.breaknine.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://app.breaknine.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/breaknine"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/changelog"
    }
  ]
}
